# IBM watsonx.ai API Configuration Template
# Copy this file to .env and fill in your actual credentials

# IBM Cloud API Key for IAM authentication
# Get this from: https://cloud.ibm.com/iam/apikeys
REACT_APP_WATSONX_API_KEY=your-api-key-here

# Watsonx.ai Project ID
# Find this in your project URL: https://dataplatform.cloud.ibm.com/projects/{PROJECT_ID}/...
REACT_APP_WATSONX_PROJECT_ID=your-project-id-here

# Watsonx.ai Region URL
# Common values: https://us-south.ml.cloud.ibm.com, https://eu-gb.ml.cloud.ibm.com
REACT_APP_WATSONX_REGION_URL=https://us-south.ml.cloud.ibm.com

# Model ID for text generation
# Available models: ibm/granite-13b-chat-v2, ibm/granite-13b-instruct-v2, etc.
REACT_APP_WATSONX_MODEL_ID=ibm/granite-13b-chat-v2