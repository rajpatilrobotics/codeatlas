# GitHub API Configuration
# Get your token from: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# AI Provider Configuration
# Get your Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get your Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# AI Provider Selection
# Default provider to use (groq or gemini)
DEFAULT_AI_PROVIDER=groq
# Fallback provider if default fails (groq or gemini)
FALLBACK_AI_PROVIDER=gemini

# Note: These environment variables should be set in:
# - Local development: Create a .env file in the root directory
# - Vercel deployment: Add them in Project Settings > Environment Variables
# 
# IMPORTANT: Never commit your actual .env file to version control!
# The .env file is already in .gitignore for your security.
#
# Migration Notes:
# - WatsonX API keys have been removed (no longer needed)
# - The application now uses Groq and/or Gemini for AI functionality
# - At least one AI provider API key is required (Groq or Gemini)
# - Both providers can be configured for automatic fallback
