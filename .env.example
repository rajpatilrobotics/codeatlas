# ============================================
# CODEATLAS - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=development
PORT=3000
SERVER_PORT=5001
API_BASE_URL=http://localhost:5001

# ============================================
# DATABASE - Neon PostgreSQL
# ============================================
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# ============================================
# REDIS - Upstash (for BullMQ & Caching)
# ============================================
UPSTASH_REDIS_URL=redis://default:your_token@your-redis.upstash.io:6379
UPSTASH_REDIS_TOKEN=your_upstash_token_here

# ============================================
# VECTOR DATABASE - Qdrant Cloud
# ============================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=codeatlas_embeddings

# ============================================
# EMBEDDINGS - Hugging Face Inference API
# ============================================
HUGGINGFACE_API_TOKEN=hf_your_token_here
HUGGINGFACE_MODEL=Alibaba-NLP/gte-Qwen2-7B-instruct
# Alternative: sentence-transformers/all-MiniLM-L6-v2

# ============================================
# LLM - DeepSeek API
# ============================================
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Alternative models: deepseek-coder, deepseek-reasoner

# ============================================
# GITHUB API
# ============================================
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_API_URL=https://api.github.com

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
REACT_APP_API_BASE_URL=http://localhost:5001
REACT_APP_ENABLE_DEVTOOLS=true

# ============================================
# QUEUE CONFIGURATION
# ============================================
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000

# ============================================
# PARSING CONFIGURATION
# ============================================
MAX_FILE_SIZE_MB=10
IGNORED_DIRECTORIES=node_modules,.next,dist,build,coverage,.git
IGNORED_EXTENSIONS=.jpg,.png,.gif,.mp4,.zip,.tar,.gz

# ============================================
# EMBEDDING CONFIGURATION
# ============================================
EMBEDDING_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNKS_PER_FILE=100

# ============================================
# AI CONFIGURATION
# ============================================
MAX_CONTEXT_LENGTH=8000
TEMPERATURE=0.7
MAX_TOKENS=2000
TOP_P=0.9

# ============================================
# SECURITY & RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=your_jwt_secret_here_change_in_production

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_here_optional
ENABLE_BULL_BOARD=true

# ============================================
# DEPLOYMENT SETTINGS (Production)
# ============================================
# VERCEL_URL=your-app.vercel.app
# RAILWAY_API_URL=your-backend.railway.app
# RAILWAY_WORKER_URL=your-worker.railway.app

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_GRAPH_VISUALIZATION=true
ENABLE_BLAST_RADIUS=true
ENABLE_SECURITY_SCANNER=true
ENABLE_AI_CHAT=true
ENABLE_HEATMAP=true

# ============================================
# NOTES:
# ============================================
# 1. NEVER commit .env file to version control
# 2. All credentials should be kept secure
# 3. Use strong, unique values for JWT_SECRET
# 4. Rotate API keys regularly
# 5. Enable 2FA on all service accounts
# 6. Use environment-specific .env files (.env.development, .env.production)