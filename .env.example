# DevDock V2 Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# IBM Watsonx.ai (Required)
# ============================================
REACT_APP_WATSONX_API_KEY=your_watsonx_api_key_here
REACT_APP_WATSONX_PROJECT_ID=your_project_id_here
REACT_APP_WATSONX_REGION_URL=https://us-south.ml.cloud.ibm.com
REACT_APP_WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ============================================
# OpenAI (Optional - for GPT-4 support)
# ============================================
REACT_APP_OPENAI_API_KEY=your_openai_api_key_here
REACT_APP_OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# Anthropic Claude (Optional)
# ============================================
REACT_APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here
REACT_APP_ANTHROPIC_MODEL=claude-3-opus-20240229

# ============================================
# Google Gemini (Optional)
# ============================================
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here
REACT_APP_GEMINI_MODEL=gemini-pro

# ============================================
# GitHub API (Required)
# ============================================
REACT_APP_GITHUB_TOKEN=your_github_personal_access_token_here

# ============================================
# Application Settings
# ============================================
REACT_APP_API_BASE_URL=http://localhost:5001
REACT_APP_DEFAULT_LLM=watsonx
PORT=3000
SERVER_PORT=5001

# ============================================
# Feature Flags (Optional)
# ============================================
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_MULTI_LLM=true
REACT_APP_ENABLE_ADVANCED_SECURITY=true
REACT_APP_ENABLE_REAL_TIME_UPDATES=true

# ============================================
# Notes:
# ============================================
# - At minimum, you need WATSONX and GITHUB credentials
# - Additional LLM keys enable multi-model comparison features
# - Keep this file secure and never commit it to version control
# - The .gitignore file is configured to exclude .env files