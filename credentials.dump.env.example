# =============================================================================
# CREDENTIALS DUMP — paste everything here, then run:  npm run credentials:apply
# =============================================================================
# 1. Copy this file:   cp credentials.dump.env.example credentials.dump.env
# 2. Paste your real keys below (replace empty values or delete unused lines)
# 3. Save, then run:   npm run credentials:apply
#
# This file is gitignored. Never commit credentials.dump.env.
# You can use any of the alias names listed in comments (e.g. HF_API_KEY).
# =============================================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=
# NEON_DATABASE_URL=

# --- Redis (Upstash) — use ONE of these styles ---
UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true

# --- Qdrant vector DB ---
QDRANT_URL=
QDRANT_API_KEY=
# QDRANT_COLLECTION=codeatlas

# --- Hugging Face (embeddings) ---
HUGGINGFACE_API_KEY=
# HUGGINGFACE_API_TOKEN=
# HF_API_KEY=

# --- DeepSeek (chat / reasoning) ---
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# --- GitHub (clone private repos) ---
GITHUB_TOKEN=
# GITHUB_API_KEY=

# --- Optional ---
# SENTRY_DSN=
# JWT_SECRET=
# API_KEY=

# --- Next.js (usually leave as-is) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# Paste extra keys from Bob below — unknown keys are ignored unless listed above
# =============================================================================
